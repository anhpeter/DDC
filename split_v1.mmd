    %% ORGANIZATIONAL STRUCTURE
    operating_concern ||--|| controlling_area : "controllingArea"
    controlling_area ||--|{ company_code : "companyCode"
    company_code ||--|{ plant : "plant"
    plant ||--|{ storage_location : "storageLocation"
    
    %% SALES ORGANIZATION
    company_code ||--|| sales_org: "salesOrg"
    sales_org ||--|{ sales_area: "salesArea"
    distribution_channel ||--|{ sales_area: "channel"
    division ||--|{ sales_area: "division"
    
    %% PURCHASING ORGANIZATION
    company_code ||--|| purchasing_org: "purchasingOrg"
    purchasing_org ||--|{ purchasing_group: "purchasingGroup"
    
    %% FI CONFIGURATION (Organization related)
    fiscal_year_variant ||--|{ controlling_area : "fiscalVariant"
    fiscal_year_variant ||--|{ company_code : "fiscalVariant"
    posting_period_variant ||--|{ company_code : "periodVariant"
